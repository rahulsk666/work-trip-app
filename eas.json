{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "remote"
  },

  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "android": {
        "image": "latest"
      }
    },

    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "image": "latest",
        "buildType": "apk"
      }
    },

    "production": {
      "distribution": "internal",
      "channel": "production",
      "android": {
        "image": "latest",
        "buildType": "apk"
      }
    }
  }
}
